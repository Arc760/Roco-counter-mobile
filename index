function loadData() {
  let saved = localStorage.getItem("items");

  if (saved) {
    let parsed = JSON.parse(saved);

    // ⭐ 防止数据结构坏掉
    if (Array.isArray(parsed)) {
      items = parsed;
    }
  }
}

function saveData() {
  localStorage.setItem("items", JSON.stringify(items));
}

function addOne(i) {
  items[i].count++;
  saveData();  
  render();
}

function minusOne(i) {
  if (items[i].count > 0) {
    items[i].count--;
  }
  saveData();
  render();
}


function handleTouchStart(e, i) {
  startX = e.touches[0].clientX;
  startY = e.touches[0].clientY;

  pressTimer = setTimeout(() => {
    showPopup(i); // 长按
  }, 600);
}

function handleTouchEnd(e, i) {
  clearTimeout(pressTimer);

  let endX = e.changedTouches[0].clientX;
  let endY = e.changedTouches[0].clientY;

  let diffX = endX - startX;
  let diffY = endY - startY;

  // 👉 判断是否“水平滑动”
  if (Math.abs(diffX) > 50 && Math.abs(diffX) > Math.abs(diffY)) {

    if (diffX > 0) {
      minusOne(i); // 向右滑动 = -1
    }
  } else {
    addOne(i); // 点击 = +1
  }
}

function handleMouseUp() {
  clearTimeout(pressTimer);
}

function showPopup(i) {
  let num = prompt("输入数字（正数=加，负数=减）");

  if (num === null) return;

  num = parseInt(num);

  if (isNaN(num)) return;

  items[i].count += num;

  if (items[i].count < 0) items[i].count = 0;

  saveData();
  render();
}

function resetAll() {
  items.forEach(item => item.count = 0);

  saveData();   
  render();
}

// 渲染
function render() {
  const container = document.getElementById("container");
  container.innerHTML = "";

  items.forEach((item, i) => {
    container.innerHTML += `
      <div class="item">
        <img src="${item.img}"
            ontouchstart="handleTouchStart(event, ${i})"
            ontouchend="handleTouchEnd(event, ${i})">
        <div>${item.name}</div>
        <div class="count">数量: ${item.count}</div>
      </div>
    `;
  });

  updateStats();
}

// 点击 +1
function addOne(i) {
  items[i].count++;
  saveData();   // ⭐必须有
  render();
}

function minusOne(i) {
  if (items[i].count > 0) {
    items[i].count--;
  }
  saveData();
  render();
}

// 属性统计
function updateStats() {
  let stats = {};

  items.forEach(item => {

    let types = Array.isArray(item.type)
      ? item.type
      : item.type.split(",");

    types.forEach(t => {
      t = t.trim();

      if (!stats[t]) stats[t] = 0;
      stats[t] += item.count;
    });

  });


  let text = "<h3>统计</h3>";
  let hasData = false;

  for (let t in stats) {
    text += `${t}: ${stats[t]}   `;
    hasData = true;
  }

  if (!hasData) {
    text += "暂无数据";
  }

  document.getElementById("stats").innerHTML = text;
}

loadData();
render();



